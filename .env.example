# Шаблон переменных окружения.
# Перед запуском: `cp .env.example .env` и заполнить значения.
# Файл .env обязателен для запуска через docker compose.

# --- API ---
API_HOST=
API_PORT=
LOG_LEVEL=
# Формат slowapi: <число>/<период>, например 10/minute
RATE_LIMIT_CREATE=

# --- PostgreSQL ---
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
# Внутри docker compose сетевое имя сервиса: postgres
# При локальном запуске вне Docker: localhost
POSTGRES_HOST=
POSTGRES_PORT=

# --- Redis / Celery ---
# Внутри docker compose: redis://redis:6379/<db>
# Локально вне Docker:   redis://localhost:6379/<db>
REDIS_URL=
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# --- Поведение воркера ---
# Вероятность (0..1) сбоя mock-вызова внешнего сервиса. По ТЗ ~0.15.
WORKER_FAILURE_RATE=
# Максимальное число ретраев одной задачи.
WORKER_MAX_RETRIES=

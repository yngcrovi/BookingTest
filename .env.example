# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
# Ограничитель для POST /bookings (формат slowapi: число/период).
RATE_LIMIT_CREATE=10/minute

# --- PostgreSQL ---
POSTGRES_USER=booking
POSTGRES_PASSWORD=booking
POSTGRES_DB=booking
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Полный URL собирается из частей выше, если переменная не задана.
# Можно переопределить целиком:
# DATABASE_URL=postgresql+psycopg2://booking:booking@postgres:5432/booking

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Поведение воркера ---
# Вероятность (0..1), что mock-вызов внешнего сервиса завершится ошибкой.
WORKER_FAILURE_RATE=0.15
# Максимальное число ретраев на одну задачу.
WORKER_MAX_RETRIES=3
